#!/bin/bash
set -e

#######################################
#	Deploy dotfiles
#		./deploy
#
#	Arguments:
#		None
#	Outputs:
#		None
#	Returns:
#		1 upon error
#		0 otherwise
#######################################
function main() {
	local readonly USAGE="Usage: ./deploy"

	if [[ "${#}" -ne 0 ]]; then
		.scripts/err "Error: no argument expected"
		.scripts/err "${USAGE}"
		return 1
	fi

	for f in `find . -type f -not -path "./.git/*" -not -path "./deploy" -not -path "./.gitignore" | cut -c3-`; do
		# Only remove files (so we don't delete ~/.config by accident)
		[[ -f "${HOME}/${f}" ]] && rm "${HOME}/${f}"

		# If dir exists in dotfiles but not in ~ => create it
		[[ -d ${f%/*} ]] && [[ ! -d "${HOME}/${f%/*}" ]] && mkdir "${HOME}/${f%/*}"

		cp "${f}" "${HOME}/${f}"
	done

	# Update .ssh/config with local key
	if [[ -f "${HOME}/.ssh/${USER}@${HOSTNAME}.pub" ]]; then
		sed -i "s/privatekey/${USER}@${HOSTNAME}/g" ~/.ssh/config
	else
		rm ~/.ssh/config
	fi

	# Set correct shell config file
	local readonly my_shell=$(echo "${SHELL}" | rev | cut -d'/' -f1 | rev)

	echo -e "#!${SHELL}\n\n[[ \$- != *i* ]] && return\n\n# If available, load polyglot:\n[ -f ~/.polyglot.sh ] && . ~/.polyglot.sh\n\n. ~/.shrc\n" > "${HOME}/.${my_shell}rc"
	sed -i "s/MYSHELL/${my_shell}/g" "${HOME}/.profile"
	ln -s "${HOME}/.profile" "${HOME}/.${my_shell}_profile"

	return 0
}

main "${@}"; exit
