#!/bin/sh
#	     _
#	 ___| |__  _ __ ___
#	/ __| '_ \| '__/ __|
#	\__ \ | | | | | (__
#	|___/_| |_|_|  \___|
#

# GPG & SSH
export GPG_TTY="$(tty)"
export SSH_KEY_PATH="$HOME/.ssh/$USER@$HOSTNAME"

# History file - infinite
HISTSIZE=-1
HISTFILESIZE=-1

# Default basic prompt
[ -z "$PS1" ] && export PS1='\$ '

# MAKEFLAGS
[ -x "$(command -v nproc)" ] && export MAKEFLAGS="-j`nproc`"

#
#	Aliases
#

# Load uutils (rust coreutils) as aliases, if available
#gen_uutils && . ~/.uutils_aliases && rm ~/.uutils_aliases

alias make="make $MAKEFLAGS"
alias ls='ls -h --color=auto'
alias ll='ls -alN --group-directories-first'
alias sctl='sudo systemctl'
alias grep='grep --color=auto'
alias mkdir='mkdir -p'
alias vim='vim -p'
alias compress='tar -czvf'
alias decompres='tar -xzvf'
