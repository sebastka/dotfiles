#!/bin/sh
set -e      # Abort upon error
set -u      # Abort upon udefined variable
#set -x     # Print every command
#set -o pipefail # Prevents errors in a pipeline from being masked (not supported by dash yet)

#######################################
#   Description:
#       Add nginx config for domain and set up SSL
#   Usage:
#       ./fm_nginx_add domain
#   Arguments:
#        domain (string): brand domain (ex: test.mailia.no)
#   Returns:
#       0 upon success
#       >=1 upon error
#######################################
main() {
    # Check if $USAGE is respected
    readonly USAGE='Usage: ./fm_nginx_add domain'
    [ "$#" -ne 1 ] && err "Error: 1 argument(s) expected, $# received" && err "$USAGE" && return 1

    # Parameters
    readonly FM_NGINX_DOMAIN="$1"
    export FM_NGINX_DOMAIN

    # Create site
    echo "$http_conf" \
        | envsubst '$FM_NGINX_DOMAIN' \
        | sudo tee "/etc/nginx/sites-available/$FM_NGINX_DOMAIN" >/dev/null

    # Enable site
    sudo ln -s "../sites-available/$FM_NGINX_DOMAIN" "/etc/nginx/sites-enabled/$FM_NGINX_DOMAIN"

    # Generate SSL certificate
    sudo certbot --nginx -d "$FM_NGINX_DOMAIN" --non-interactive --agree-tos --email 'hello@fjordmail.no'

    sudo mv "/etc/nginx/sites-available/$FM_NGINX_DOMAIN" "/tmp/$FM_NGINX_DOMAIN.temp.conf"
    cat -s "/tmp/$FM_NGINX_DOMAIN.temp.conf" \
        | sed '29d;41d' \
        | sed '29G;36G' \
        | sed -e '$a\' \
        | sed "37 a \ \ \ \ access_log /var/log/nginx/access.http.$FM_NGINX_DOMAIN.log;" \
        | sed "38 a \ \ \ \ error_log /var/log/nginx/error.http.$FM_NGINX_DOMAIN.log;" \
        | sed 's/443 ssl/& http2/g' \
        | sudo tee "/etc/nginx/sites-available/$FM_NGINX_DOMAIN" >/dev/null
    
    sudo systemctl reload nginx
}

readonly http_conf='server {
    server_name ${FM_NGINX_DOMAIN};

    root /home/fjordmail/www/${FM_NGINX_DOMAIN}/public_html;
    index index.php;

    location / {
        try_files $uri $uri/ =404;
    }

    location ~ \.php$ {
        include snippets/fastcgi-php.conf;
        fastcgi_pass unix:/run/php/php-fpm.sock;
    }

    location ~ /\.ht {
        deny all;
    }

    access_log /var/log/nginx/access.https.${FM_NGINX_DOMAIN}.log;
    error_log /var/log/nginx/error.https.${FM_NGINX_DOMAIN}.log;

    listen [::]:80;
    listen 80;
}'

#######################################
#   Print error message to stderr
#   https://google.github.io/styleguide/shellguide.html
#######################################
err() { echo "[$(date +'%Y-%m-%dT%H:%M:%S%z')]: $*" >&2; }

main "$@"; exit
