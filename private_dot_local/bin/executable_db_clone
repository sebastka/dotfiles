#!/bin/sh
set -eux

readonly dump_path="$(mktemp -d)/db.sql"

main()
{
    dump_db && clone_db
    rm -rf "$dump_path"
}

dump_db()
{
    printf 'Source database name: '
    read -r s_db_name

    printf 'Source database user: '
    read -r s_db_user

    printf 'Source database host (default: localhost): '
    read -r s_db_host
    [ ! -z "$s_db_host" ] || s_db_host='localhost'

    mysqldump \
        --user="$s_db_user" \
        --password="$s_db_pass" \
        --host="$s_db_host" \
        --password \
        "$s_db_name" \
        > "$db_dump_file"
}

clone_db()
{
    printf 'Destination database name: '
    read -r d_db_name

    printf 'Destination database user: '
    read -r d_db_user

    printf 'Destination database host (default: localhost): '
    read -r d_db_host
    [ ! -z "$d_db_host" ] || d_db_host='localhost'

    mysql \
        --user="$d_db_user" \
        --password="$d_db_pass" \
        --host="$d_db_host" \
        --password \
        "$d_db_name" \
        < "$db_dump_file"
}

get_input()
{
    
    echo "$r"
}

main "$@"; exit
