#!/bin/sh
set -eu

readonly dump_path="$(mktemp -d)/db.sql"

main()
{
    dump_db && clone_db
    rm -rf "$dump_path"
}

dump_db()
{
    s_db_name="$(get_input 'Source database name')"
    s_db_user="$(get_input 'Source database user')"
    s_db_host="$(get_input 'Source database host (default: localhost)')"
    [ ! -z "$s_db_host" ] || s_db_host='localhost'

    mysqldump \
        --user="$s_db_user" \
        --password="$s_db_pass" \
        --host="$s_db_host" \
        "$s_db_name" \
        > "$db_dump_file"
}

clone_db()
{
    d_db_name="$(get_input 'Destination database name')"
    d_db_user="$(get_input 'Destination database user')"
    d_db_host="$(get_input 'Destination database host (default: localhost)')"
    [ ! -z "$d_db_host" ] || d_db_host='localhost'

    mysql \
        --user="$d_db_user" \
        --password="$d_db_pass" \
        --host="$d_db_host" \
        "$d_db_name" \
        < "$db_dump_file"
}

get_input()
{
    printf '%s: ' "$1"
    read -r r
    echo "$r"
}

main "$@"; exit
