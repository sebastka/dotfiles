#!/bin/sh
set -e      # Abort upon error
set -u      # Abort upon udefined variable
set -x     # Print every command


#######################################
#   Description:
#       Actions on VM using PVE API
#   Usage:
#       ./pve [-l pve_url] [-n pve_node] [-u pve_user] vm_id action
#   Arguments:
#        -l pve_url
#        -n pve_node
#        -u pve_user (Default: 'root@pam')
#        vm_id (int): ID of VM to perform action on
#        action (string): Action to perform on VM (Default: 'status')
#   Returns:
#       0 upon success
#       >=1 upon error
#######################################
main() {
    # Set up eac3to
    readonly EAC3TO_PATH="${WINEPREFIX-~/.wine}/drive_c/Program\ Files"
    eactto
}

install_eactto() {
    curl -s -o /tmp/eac3to.zip http://madshi.net/eac3to.zip
    unzip /tmp/eac3to.zip -d "$EAC3TO_PATH"
}



#######################################
#   Print error message to stderr
#   https://google.github.io/styleguide/shellguide.html
#######################################
err() { echo "[$(date +'%Y-%m-%dT%H:%M:%S%z')]: $*" >&2; }

main "$@"; exit
