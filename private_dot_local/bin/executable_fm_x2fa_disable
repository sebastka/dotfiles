#!/bin/sh
set -e      # Abort upon error
set -u      # Abort upon udefined variable
#set -x     # Print every command
#set -o pipefail # Prevents errors in a pipeline from being masked (not supported by dash yet)

#######################################
#   Description:
#       Disable x2fa for the passed user
#   Usage:
#       ./fm_x2fa_disable username
#   Arguments:
#        username (string): desc
#   Returns:
#       0 upon success
#       >=1 upon error
#######################################
main() {
    # Check if $USAGE is respected
    readonly USAGE='Usage: ./fm_x2fa_disable username'
    [ "$#" -ne 1 ] && err "Error: 1 argument(s) expected, $# received" && err "$USAGE" && return 1

    # Parameters
    readonly username="$1"

    # Add to skiplist
    ssh -n data01.fjordmail.no "printf '%s,%s\n' "$(date +'%F')" "$username" >> /mnt/rc_temp/x2fa_disabled.csv"
    #ssh -n dev.fjordmail.no "printf '%s,%s\n' "$(date +'%F')" "$username" >> /var/www/.temp/x2fa_disabled.csv"
}

#######################################
#   Print error message to stderr
#   https://google.github.io/styleguide/shellguide.html
#######################################
err() { echo "[$(date +'%Y-%m-%dT%H:%M:%S%z')]: $*" >&2; }

main "$@"; exit
