#!/bin/bash
set -e
#set -x

#######################################
#	Download Win10 ISO
#	Inspired from https://gist.github.com/hongkongkiwi/15a5bf16437315df256c118c163607cb
#	See also:
#	https://tb.rg-adguard.net/public.php
#	https://www.microsoft.com/en-us/software-download/windows10ISO
#		get_win [language [output]]
#
#	Arguments:
#		language (string): optional language of Win10 - Default English
#		output (string): optional filename of output
#	Outputs:
#		None
#	Returns:
#		1 upon error
#		0 otherwise
#######################################
function main() {
	local readonly USAGE="Usage: get_win [language [output]]"

	if [[ "${#}" -gt 2 ]]; then
		err "Error: at most two arguments expected, ${#} received"
		err "${USAGE}"
		return 1
	fi

	# Set default lang to English
	# and change to $1 if provided
	local LANG_NAME="English"
	[[ "$#" -ge 1 ]] && LANG_NAME="${1}"

	# Get file info
	local readonly ARCH="x64"
	local readonly LATEST_WINDOWS_VERSION=`curl -s -H "Accept: application/json" "https://tb.rg-adguard.net/php/get_version.php?type_id=1" | jq '.versions | sort_by(-(.version_id | tonumber))[0]'`
	local readonly WINDOWS_NAME=`echo "${LATEST_WINDOWS_VERSION}" | jq -r .name`
	local readonly VERSION_ID=`echo "${LATEST_WINDOWS_VERSION}" | jq -r .version_id`
	local readonly EDITION_ID=`curl -s -H "Accept: application/json" "https://tb.rg-adguard.net/php/get_edition.php?version_id=${VERSION_ID}&lang=name_en" | jq -r '.editions[] | select(.name_en=="Windows 10").edition_id'`
	local readonly LANGUAGE_ID=`curl -s -H "Accept: application/json" "https://tb.rg-adguard.net/php/get_language.php?edition_id=${EDITION_ID}&lang=name_en" | jq -r '.languages[] | select(.name_en=="'${LANG_NAME}'").language_id'`
	local readonly ARCH_INFO=`curl -s -H "Accept: application/json" "https://tb.rg-adguard.net/php/get_arch.php?language_id=${LANGUAGE_ID}"`
	local readonly FILE_NAME=`echo "${ARCH_INFO}" | jq -r '.archs[] | select(.name | contains("'${ARCH}'")).name'`
	local readonly ARCH_ID=`echo "${ARCH_INFO}" | jq -r '.archs[] | select(.name | contains("'${ARCH}'")).arch_id'`
	local readonly DOWNLOAD_INFO=`curl -s "https://tb.rg-adguard.net/dl.php?fileName=${ARCH_ID}&lang=en"`
	local readonly DOWNLOAD_ID=`echo "${DOWNLOAD_INFO}" | grep -oP '(?<=https:\/\/tb\.rg-adguard\.net/dl\.php\?go=)[0-9a-z]+'`
	local readonly DOWNLOAD_URL="https://tb.rg-adguard.net/dl.php?go=${DOWNLOAD_ID}"
	local readonly FILE_SIZE_MB=`echo "${DOWNLOAD_INFO}" | grep -oP "(?<=File size: </b>)[0-9.]+"`
	local readonly FILE_SIZE_BYTES=`echo "${DOWNLOAD_INFO}" | grep -oP "(?<=File size: </b>)[0-9(). A-Z]+" | cut -d "(" -f2 | tr -d ' '`

	## Debug
	# echo "ARCH=${ARCH}"
	# echo "LATEST_WINDOWS_VERSION=${LATEST_WINDOWS_VERSION}"
	# echo "WINDOWS_NAME=${WINDOWS_NAME}"
	# echo "VERSION_ID=${VERSION_ID}"
	# echo "EDITION_ID=${EDITION_ID}"
	# echo "LANGUAGE_ID=${LANGUAGE_ID}"
	# echo "ARCH_INFO=${ARCH_INFO}"
	# echo "FILE_NAME=${FILE_NAME}"
	# echo "ARCH_ID=${ARCH_ID}"
	# echo "DOWNLOAD_INFO=${DOWNLOAD_INFO}"
	# echo "DOWNLOAD_ID=${DOWNLOAD_ID}"
	# echo "DOWNLOAD_URL=${DOWNLOAD_URL}"
	# echo "FILE_SIZE_MB=${FILE_SIZE_MB}"
	# echo "FILE_SIZE_BYTES=${FILE_SIZE_BYTES}"

	# If at least one var i empty, abort
	[[ -z "${ARCH}" ]] && err "Error: \$ARCH is void" && return 1
	[[ -z "${LATEST_WINDOWS_VERSION}" ]] && err "Error: \$LATEST_WINDOWS_VERSION is void" && return 1
	[[ -z "${WINDOWS_NAME}" ]] && err "Error: \$WINDOWS_NAME is void" && return 1
	[[ -z "${VERSION_ID}" ]] && err "Error: \$VERSION_ID is void" && return 1
	[[ -z "${EDITION_ID}" ]] && err "Error: \$EDITION_ID is void" && return 1
	[[ -z "${LANGUAGE_ID}" ]] && err "Error: \$LANGUAGE_ID is void" && return 1
	[[ -z "${ARCH_INFO}" ]] && err "Error: \$ARCH_INFO is void" && return 1
	[[ -z "${FILE_NAME}" ]] && err "Error: \$FILE_NAME is void" && return 1
	[[ -z "${ARCH_ID}" ]] && err "Error: \$ARCH_ID is void" && return 1
	[[ -z "${DOWNLOAD_INFO}" ]] && err "Error: \$DOWNLOAD_INFO is void" && return 1
	[[ -z "${DOWNLOAD_ID}" ]] && err "Error: \$DOWNLOAD_ID is void" && return 1
	[[ -z "${DOWNLOAD_URL}" ]] && err "Error: \$DOWNLOAD_URL is void" && return 1
	[[ -z "${FILE_SIZE_MB}" ]] && err "Error: \$FILE_SIZE_MB is void" && return 1
	[[ -z "${FILE_SIZE_BYTES}" ]] && err "Error: \$FILE_SIZE_BYTES is void" && return 1


	if [[ -f "${FILE_NAME}" ]]; then
		local readonly EXISTING_BYTES=`stat --printf="%s" "${FILE_NAME}"`

		if [[] "${EXISTING_BYTES}" -eq "${FILE_SIZE_BYTES}" ]]; then
			err "Error: complete iso already stored at ${FILE_NAME}"
			return 1
		else
			err "File does exist but has wrong bytesize! (got ${EXISTING_BYTES} expected ${FILE_SIZE_BYTES})"
			err "Probably corrupt or incomplete - removing"
			rm "${FILE_NAME}"
		fi
	fi

	echo "Downloading ${FILE_NAME} (${FILE_SIZE_MB} Mb [${FILE_SIZE_BYTES} bytes])"

	# If second arg is provided, store file to $2
	if [ "${#}" -eq 2 ]; then
		FILE_NAME="${2}"
	fi

	# Download file
	curl -s -L "${DOWNLOAD_URL}" -o "${FILE_NAME}"

	# Checksum
	local readonly shasum=`sha1sum "${FILE_NAME}" | cut -d ' ' -f1`

	if curl -s https://sha1.rg-adguard.net/search.php?sha1="${shasum}" | grep -q "<b>It is found in  msdn.rg-adguard.net:</b> 1"; then
		echo "Checkum OK"
	else
		echo "Cheksum failed! Please try again"
		rm "${FILE_NAME}"
		return 1
	fi

	return 0
}

main "${@}"; exit
